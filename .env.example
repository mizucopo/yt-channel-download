# YouTube Channel IDs (comma-separated)
YOUTUBE_CHANNEL_IDS=UCxxxxxxxxxxxxxxxxxx

# Google OAuth Configuration
GOOGLE_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Google Drive Folder ID (destination for uploads)
GDRIVE_ROOT_FOLDER_ID=your_folder_id

# Optional: Override default paths
# DATABASE_PATH=data/databases/streams.db
# DOWNLOAD_DIR=data/downloads
# THUMBNAIL_DIR=data/thumbnails

# Optional: Override default settings
# THUMBNAIL_INTERVAL=60
# THUMBNAIL_QUALITY=2
# MAX_RETRIES=3
# LOCK_STALE_HOURS=3

# Optional: Discord notifications
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
